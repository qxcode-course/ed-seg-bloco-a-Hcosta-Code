{"ts":1783461217,"hash":"d6761f4158c1b2dc669fdbc589a95a418fff8c7b8052733e7977cd6821d9eea1","mode":"diff","ops":[{"tag":"insert","a1":0,"a2":0,"text":"package main\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n)\n\n// Node representa um nó na árvore binária.\ntype Node struct {\n\tValue int\n\tLeft  *Node\n\tRight *Node\n}\n\n// create constrói uma árvore binária a partir de uma lista de strings.\n// Consuma os elementos da lista sempre do início.\n// Você pode obter o primeiro elemento com 'elem := (*parts)[0]'\n// Você pode fazer um \"push_front\" no array usando '*parts = (*parts)[1:]\n// Se o elemento for \"#\", significa que o nó é nulo.\nfunc create(parts *[]string) *Node {\n\t_ = parts\n\treturn nil\n}\n\n// BShow é uma função auxiliar para imprimir a árvore binária.\n// Primeira invocação de ser com history como uma string vazia.\nfunc BShow(node *Node, history string) {\n\tif node != nil && (node.Left != nil || node.Right != nil) {\n\t\tBShow(node.Left, history+\"l\")\n\t}\n\n\tfor i := 0; i < len(history)-1; i++ {\n\t\tif history[i] != history[i+1] {\n\t\t\tfmt.Print(\"│   \")\n\t\t} else {\n\t\t\tfmt.Print(\"    \")\n\t\t}\n\t}\n\tif history != \"\" {\n\t\tif history[len(history)-1] == 'l' {\n\t\t\tfmt.Print(\"╭───\")\n\t\t} else {\n\t\t\tfmt.Print(\"╰───\")\n\t\t}\n\t}\n\tif node == nil {\n\t\tfmt.Println(\"#\")\n\t\treturn\n\t}\n\tfmt.Println(node.Value)\n\tif node.Left != nil || node.Right != nil {\n\t\tBShow(node.Right, history+\"r\")\n\t}\n}\n\nfunc main() {\n\tscanner := bufio.NewScanner(os.Stdin)\n\tscanner.Scan()\n\tline := scanner.Text()\n\tparts := strings.Split(line, \" \")\n\troot := create(&parts)\n\tBShow(root, \"\")\n}\n"}]}
{"ts":1783461452,"hash":"692d259339d365e31492bde1438f96a237ba6c03bb235dddaf65edcdd73b7cff","mode":"diff","ops":[{"tag":"replace","a1":6,"a2":7,"text":"\t\"strconv\"\n"},{"tag":"delete","a1":9,"a2":10,"text":""},{"tag":"delete","a1":16,"a2":21,"text":""},{"tag":"replace","a1":22,"a2":24,"text":"\tif len(*parts) == 0 {\n\t\treturn nil\n\t}\n\n\tvalStr := (*parts)[0]\n\t*parts = (*parts)[1:]\n\n\tif valStr == \"#\" {\n\t\treturn nil\n\t}\n\n\tval, _ := strconv.Atoi(valStr)\n\tnode := &Node{Value: val}\n\n\tnode.Left = create(parts)\n\tnode.Right = create(parts)\n\n\treturn node\n"},{"tag":"delete","a1":26,"a2":28,"text":""},{"tag":"replace","a1":42,"a2":43,"text":"\t\t\tfmt.Print(\"┌───\") // Bordas quadradas como o TKO quer\n"},{"tag":"replace","a1":44,"a2":45,"text":"\t\t\tfmt.Print(\"└───\") // Bordas quadradas como o TKO quer\n"},{"tag":"replace","a1":59,"a2":64,"text":"\t\n\tscanner.Split(bufio.ScanWords)\n\n\tvar parts []string\n\n\tfor scanner.Scan() {\n\t\tparts = append(parts, scanner.Text())\n\t}\n\n\tif len(parts) > 0 {\n\t\troot := create(&parts)\n\t\tBShow(root, \"\")\n\t}\n"}]}
